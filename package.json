{
  "name": "musalink",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k --names common,backend,frontend \"npm run dev -w musalink-common\" \"npm run dev -w musalink-backend\" \"npm run dev -w musalink-frontend\"",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "build": "npm run build:common && npm run build:backend && npm run build:frontend",
    "build:common": "npm run build -w musalink-common",
    "build:backend": "npm run build -w musalink-backend",
    "build:frontend": "npm run build -w musalink-frontend"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.8"
  }
}
